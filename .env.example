# ============================================
# MCDAutoTrader Bot - Configuration Template
# Copy to .env and fill in your values
# ============================================

# --- Core ---
ENV=dev
TZ=America/Vancouver
DB_PATH=./bot.db
LOG_LEVEL=INFO

# --- Feature Flags (all false by default) ---
FEATURE_MULTI_PAIR=false
FEATURE_AI_FUSION=false
FEATURE_CANDLE_PATTERNS=false
FEATURE_HIDDEN_DIVERGENCE=false
FEATURE_MARKET_REGIME=false

# --- Market / Exchange ---
EXCHANGE=kraken
PAIR=BNB/USDC
TIMEFRAMES=30m,1h,4h,1d
CANDLE_LIMIT=300
PAPER_TRADING=true

# --- Multi-Pair ---
DEFAULT_PAIRS=BNB/USDC
MAX_WATCHED_PAIRS=10
PAIR_MODE=single

# --- Risk ---
CAPITAL_USD=1000
RISK_PER_TRADE=0.01
MAX_OPEN_TRADES=2
DAILY_LOSS_LIMIT_USD=50
ENABLE_EXIT_AUTOMATION=true
COOLDOWN_AFTER_TRADE_SECONDS=300
MAX_DAILY_TRADES=10
CONSECUTIVE_LOSS_COOLDOWN=3
CONSECUTIVE_LOSS_PAUSE_SECONDS=3600
BREAK_EVEN_ATR_MULTIPLIER=1.0

# --- Kill Switch / Dry Run ---
KILL_SWITCH=false
DRY_RUN_MODE=false

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
HTTPS_PROXY=

# --- AI / Decider (legacy) ---
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_CONFIDENCE_MIN=0.65
SIGNAL_SCORE_MIN=0.60

# --- AI Fusion (dual-AI) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_FUSION_POLICY=local_only
AI_TIMEOUT_SECONDS=15

# --- Indicators / Strategy ---
ATR_PERIOD=14
ADX_PERIOD=14
ADX_TREND_MIN=20.0
ADX_STRONG_TREND=40.0
BB_PERIOD=20
BB_STD=2.0
PIVOT_LOOKBACK=3
ATR_SL_MULTIPLIER=1.5

# --- Candle Patterns ---
CANDLE_WICK_RATIO=2.0
CANDLE_BODY_RATIO=0.3

# --- Market Regime ---
REGIME_EMA_FAST=20
REGIME_EMA_SLOW=50
REGIME_ADX_THRESHOLD=25.0
REGIME_VOLATILITY_LOOKBACK=20

# --- Scheduler ---
ANALYSIS_INTERVAL_SECONDS=600
GUARD_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_INTERVAL_SECONDS=3600

# --- Kraken / Live Trading ---
LIVE_TRADE_ALLOWED_IDS=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
