import os, json, requests\
from typing import Optional, Dict, Any\
from fastapi import FastAPI, Header, HTTPException\
from pydantic import BaseModel\
import uvicorn\
\
AUTH_TOKEN = os.getenv("AI_SERVICE_AUTH", "local-secret-123")  # \uc0\u1578 \u1608 \u1705 \u1606  \u1582 \u1589 \u1608 \u1589 \u1740  \u1582 \u1608 \u1583 \u1578 \
OPENAI_KEY = os.getenv("OPENAI_API_KEY", "")                   # \uc0\u1575 \u1582 \u1578 \u1740 \u1575 \u1585 \u1740 \
\
app = FastAPI(title="AI Decider Service")\
\
class DecideRequest(BaseModel):\
    features: Dict[str, Any]\
    user_profile: Optional[Dict[str, Any]] = None\
\
def heuristics(features: Dict[str, Any]) -> Dict[str, Any]:\
    merged = features.get("merged", \{\})\
    direction = merged.get("merged_direction") or features.get("merged_signal") or "HOLD"\
    score = float(merged.get("merged_score", 0.0))\
    decision, conf, notes = "HOLD", 0.55, "Heuristic fallback"\
    if direction == "BUY" and score > 0.6:\
        decision, conf, notes = "ENTER", min(0.9, 0.55 + score/2), "Heuristic BUY"\
    elif direction == "SELL" and score < -0.6:\
        decision, conf, notes = "EXIT", min(0.9, 0.55 + abs(score)/2), "Heuristic SELL"\
    return \{"decision": decision, "confidence": conf, "notes": notes\}\
\
def ask_openai(features: Dict[str, Any]) -> Optional[Dict[str, Any]]:\
    if not OPENAI_KEY:\
        return None  # \uc0\u1575 \u1587 \u1578 \u1601 \u1575 \u1583 \u1607  \u1575 \u1586  OpenAI \u1575 \u1582 \u1578 \u1740 \u1575 \u1585 \u1740 \u1607 \
    prompt = (\
        "You are a trading decider. Based on these features, respond with JSON only.\\n"\
        f"\{json.dumps(features, ensure_ascii=False)\}\\n"\
        'Keys: \{"decision": "ENTER|EXIT|HOLD", "confidence": 0..1, "notes": "short"\}'\
    )\
    try:\
        payload = \{\
            "model": "gpt-4o-mini",\
            "messages": [\
                \{"role": "system", "content": "You are an accurate trading decider. Output concise JSON only."\},\
                \{"role": "user", "content": prompt\},\
            ],\
            "temperature": 0.2,\
            "response_format": \{"type": "json_object"\},\
        \}\
        r = requests.post(\
            "https://api.openai.com/v1/chat/completions",\
            headers=\{"Authorization": f"Bearer \{OPENAI_KEY\}", "Content-Type": "application/json"\},\
            json=payload,\
            timeout=15,\
        )\
        r.raise_for_status()\
        content = r.json()["choices"][0]["message"]["content"]\
        data = json.loads(content)\
        return \{\
            "decision": data.get("decision", "HOLD"),\
            "confidence": float(data.get("confidence", 0.55)),\
            "notes": data.get("notes", "openai"),\
        \}\
    except Exception:\
        return None\
\
@app.post("/decide")\
def decide(req: DecideRequest, authorization: Optional[str] = Header(None)):\
    if AUTH_TOKEN and (authorization or "") != f"Bearer \{AUTH_TOKEN\}":\
        raise HTTPException(status_code=401, detail="Unauthorized")\
    out = ask_openai(req.features)\
    if not out:\
        out = heuristics(req.features)\
    return out\
\
if __name__ == "__main__":\
    uvicorn.run("ai_service:app", host="127.0.0.1", port=8000)\
}